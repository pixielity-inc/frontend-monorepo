# ==============================================================================
# Next.js — Staging Environment
# ==============================================================================
# Staging configuration — production-like, pointed at staging APIs.
# Analytics enabled at 10% sampling.
# ==============================================================================


# ==============================================================================
# APPLICATION
# ==============================================================================

NEXT_PUBLIC_APP_NAME=Pixielity Staging
NEXT_PUBLIC_APP_VERSION=0.0.1
NEXT_PUBLIC_APP_ENV=staging
NODE_ENV=production


# ==============================================================================
# API
# ==============================================================================

NEXT_PUBLIC_API_BASE_URL=https://staging-api.pixielity.com
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_API_TIMEOUT_MS=30000
API_INTERNAL_BASE_URL=http://api:8080
API_SECRET_KEY=


# ==============================================================================
# AUTHENTICATION
# ==============================================================================

NEXT_PUBLIC_AUTH_STRATEGY=jwt
NEXTAUTH_URL=https://staging.pixielity.com
NEXTAUTH_SECRET=
AUTH_OAUTH2_CLIENT_ID=
AUTH_OAUTH2_CLIENT_SECRET=
AUTH_OAUTH2_ISSUER=
AUTH_OAUTH2_REDIRECT_URI=https://staging.pixielity.com/api/auth/callback
NEXT_PUBLIC_AUTH_SESSION_TIMEOUT_S=86400


# ==============================================================================
# DATABASE
# ==============================================================================

DATABASE_URL=postgresql://pixielity:secret@postgres:5432/pixielity_staging
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10


# ==============================================================================
# REDIS
# ==============================================================================

REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_DB=0


# ==============================================================================
# ANALYTICS
# ==============================================================================

NEXT_PUBLIC_ANALYTICS_ENABLED=true
NEXT_PUBLIC_ANALYTICS_CRASH_ENABLED=true
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_MIXPANEL_TOKEN=
NEXT_PUBLIC_POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=pixielity
SENTRY_PROJECT=web-staging
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1


# ==============================================================================
# FEATURE FLAGS
# ==============================================================================

NEXT_PUBLIC_FLAG_NEW_ONBOARDING=true
NEXT_PUBLIC_FLAG_AI_ASSISTANT=false
NEXT_PUBLIC_FLAG_PREMIUM_THEMES=false
NEXT_PUBLIC_FLAG_NEW_DASHBOARD=false
NEXT_PUBLIC_FLAGS_REMOTE_PROVIDER=none
FLAGS_REMOTE_SDK_KEY=
NEXT_PUBLIC_FLAGS_REMOTE_ENDPOINT=


# ==============================================================================
# WEBSOCKETS / REALTIME
# ==============================================================================

NEXT_PUBLIC_WS_ENABLED=false
NEXT_PUBLIC_WS_URL=wss://staging-ws.pixielity.com
NEXT_PUBLIC_REVERB_APP_KEY=
NEXT_PUBLIC_REVERB_HOST=staging-ws.pixielity.com
NEXT_PUBLIC_REVERB_PORT=443
NEXT_PUBLIC_REVERB_SCHEME=wss


# ==============================================================================
# STORAGE / CDN
# ==============================================================================

NEXT_PUBLIC_CDN_URL=https://cdn.staging.pixielity.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=pixielity-staging
AWS_ENDPOINT=


# ==============================================================================
# MAIL
# ==============================================================================

MAIL_FROM_ADDRESS=noreply@pixielity.com
MAIL_FROM_NAME=Pixielity
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=


# ==============================================================================
# LOGGING
# ==============================================================================

NEXT_PUBLIC_LOG_LEVEL=info
LOG_REMOTE_ENDPOINT=
LOG_REMOTE_API_KEY=
