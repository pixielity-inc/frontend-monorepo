{
  "name": "@abdokouta/ts-container-react",
  "version": "1.2.2",
  "description": "React bindings for @abdokouta/ts-container. ContainerProvider, useInject, useOptionalInject, useContainer hooks.",
  "keywords": [
    "dependency-injection",
    "di",
    "react",
    "hooks",
    "container",
    "provider",
    "useInject",
    "typescript"
  ],
  "license": "MIT",
  "author": "Pixielity",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "dependencies": {
    "@abdokouta/ts-container": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "@nesvel/typescript-config": "^1.0.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "eslint": "10.2.0",
    "prettier": "^3.8.1",
    "@nesvel/tsup-config": "^1.0.3",
    "@nesvel/eslint-config": "^1.0.5",
    "@nesvel/prettier-config": "^1.0.3",
    "@vitest/ui": "^4.1.2",
    "jsdom": "^29.0.1",
    "typescript-eslint": "^8.58.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
