{
  "name": "@abdokouta/react-router",
  "version": "1.0.0",
  "description": "Route auto-registration package with @Route decorator and RouteRegistry for @abdokouta/react-refine.",
  "license": "MIT",
  "author": {
    "name": "Abdelrhman Kouta",
    "email": "abdelrhman@abdokouta.com",
    "url": "https://github.com/abdokouta"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pixielity-inc/frontend-monorepo.git",
    "directory": "packages/router"
  },
  "keywords": [
    "react",
    "router",
    "route",
    "decorator",
    "auto-registration",
    "dependency-injection"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "10.2.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "@nesvel/typescript-config": "^1.0.4",
    "@nesvel/tsup-config": "^1.0.3",
    "@nesvel/eslint-config": "^1.0.5",
    "@nesvel/prettier-config": "^1.0.3",
    "@vitest/ui": "^4.1.2",
    "typescript-eslint": "^8.58.0"
  },
  "peerDependencies": {
    "@abdokouta/react-refine": "workspace:*",
    "@abdokouta/ts-container": "workspace:*",
    "@abdokouta/ts-support": "workspace:*",
    "react-router-dom": "^6.0.0 || ^7.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependenciesMeta": {
    "@abdokouta/react-refine": {
      "optional": false
    },
    "@abdokouta/ts-container": {
      "optional": false
    },
    "react-router-dom": {
      "optional": false
    },
    "reflect-metadata": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
